	// Prevent named mobs from becoming Elite, Ultra, and Eldritch
	"ignoreNamedMobs": true,
	// Turn off titles for mobs
	"turnOffTitles": true,
	// Turn off boss bars
	"turnOffBossBars": false,
	// Boss bars appears when placing crosshair on buffed mob
	"crosshairBossBars": true,
	// Buffed mobs are highlighted after being damaged
	"turnOnGlowingMobs": true,
	// Turn off loot for buffed mobs
	"disableLootDrops": false,
	// If true, buffed mobs only drop loot when killed by players
	"onlyDropLootIfKilledByPlayers": true,
	// Buffed mobs also drop the loot of the tier below them + the loot of their tier.
	"combinedLootDrop": false,
	// Buffed mobs have generic titles w/o abilities
	"genericTitles": false,
	// Allows to see eldritch mobs' name tags from any distance
	"distantVisibleNameTags": false,
